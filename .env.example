# =============================================================================
# KEALEX - CONFIGURAÇÕES DE AMBIENTE (EXEMPLO)
# =============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# -----------------------------------------------------------------------------
# SEGURANÇA
# -----------------------------------------------------------------------------
SECRET_KEY=troque-por-uma-chave-segura-em-producao

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------
DATABASE_URL=mysql+pymysql://<usuario>:<senha>@<host>:3306/<banco>

# Configurações individuais do banco (caso necessário)
DB_HOST=<host>
DB_PORT=3306
DB_NAME=<banco>
DB_USER=<usuario>
DB_PASSWORD=<senha>

# -----------------------------------------------------------------------------
# TRAEFIK / DOMÍNIO
# -----------------------------------------------------------------------------
DOMAIN=srv1023256.hstgr.cloud
CORS_ORIGINS=https://srv1023256.hstgr.cloud,http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# JWT CONFIGURAÇÕES
# -----------------------------------------------------------------------------
JWT_SECRET=troque-por-uma-chave-jwt-segura
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# UPLOAD / ARQUIVOS
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,doc,docx,jpg,jpeg,png,gif

# -----------------------------------------------------------------------------
# EMAIL / SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=false
SMTP_TLS=true
SMTP_USER=admin@kealex.com.br
SMTP_PASS=<sua-senha-email>

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
APP_NAME=Kealex
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
BASE_URL=https://srv1023256.hstgr.cloud

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_URL=https://srv1023256.hstgr.cloud
FRONTEND_LOCAL_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/kealex.log

# -----------------------------------------------------------------------------
# CACHE / REDIS (se necessário)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# INTEGRAÇÃO IA
# -----------------------------------------------------------------------------
# Cerebras
CEREBRAS_API_KEY=<sua-chave-cerebras>
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Groq
GROQ_API_KEY=<sua-chave-groq>
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Modelo padrão
DEFAULT_AI_PROVIDER=cerebras
DEFAULT_AI_MODEL=llama-3.3-70b

# -----------------------------------------------------------------------------
# BACKUP
# -----------------------------------------------------------------------------
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# MONITORAMENTO
# -----------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# TIMEZONE
# -----------------------------------------------------------------------------
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# DOCKER / DEPLOY
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=kealex
DOCKER_REGISTRY=kealex
IMAGE_TAG=latest